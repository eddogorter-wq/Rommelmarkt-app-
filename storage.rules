rules_version = '2';
service firebase.storage {
  match /b/lelu-1nwjh0.firebasestorage.app/o {
    match /listings/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
